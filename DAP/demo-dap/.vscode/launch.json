{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ]
    },
    {
      "type": "fake-debug",
      "request": "launch",
      "name": "Fake Debug Launch",
      "program": "out/adapter/debugAdapter.js"
    }
  ]
}
